# Regenerable / runtime artifacts. Mirrors the sister-lab repo policy.
# Raw archives and parquet are large and reproducible from the source, so they
# are never committed. Only code + docs go in version control.
LAB/data/
LAB/parquet/
LAB/logs/
*.bak
*.log
__pycache__/
.signal_cache/
# Python virtualenv (the dedicated Ostium-SDK venv; ~400 MB, machine-specific, rebuildable).
.venv/

# ---------------------------------------------------------------------------
# Secrets and credentials. NEVER commit these. The project reads its real
# secrets (Ostium signing key, RPC URLs, tokens) from ~/.env at runtime, by
# variable name only, so nothing sensitive belongs in version control. These
# patterns are a safety net so a stray key file or a local .env can never be
# staged by accident. Example templates (.env.example etc.) stay committable.
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.sample
!.env.template
*.pem
*.key
*.keystore
keystore/
*.p12
*.pfx
*.ppk
id_rsa
id_ed25519
.git-credentials
*.secrets
secrets.json
secrets.yaml
